<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login – Elohim Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>

<!-- ═══════════════════════════════════════  NAVBAR  ════ -->
<nav class="navbar navbar-expand-lg navbar-elohim sticky-top">
    <div class="container">
        <a class="navbar-brand" href="/">
            <img src="/static/logos/logo-elohim.png" alt="Elohim Hotel" class="navbar-logo-img">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false"
                aria-label="Toggle navigation"
                style="border-color:rgba(201,168,76,.4)">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            
        </div>
    </div>
</nav>

<!-- ═══════════════════════════════════════  FLASH MESSAGES  ════ -->
<div class="container mt-4">
    
        
            
                <div class="alert alert-message alert-dismissible fade show" role="alert">
                    <i class="bi bi-info-circle-fill me-1"></i>
                    Please log in to access this page.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            
        
    
</div>

<!-- ═══════════════════════════════════════  CONTENT  ════ -->
<main class="flex-fill">

<div class="login-wrap">
    <div class="login-card animate-in">
        <!-- Brand -->
        <div class="login-brand">
            <div class="hotel-name"><img src="/static/logos/logo-elohim.png" alt="Elohim Hotel" class="login-logo-img"> Elohim<span style="color:var(--gold)">Hotel</span></div>
            <div class="hotel-sub">Sistem Informasi Absensi Karyawan</div>
        </div>

        <form method="POST" novalidate>
            <input id="csrf_token" name="csrf_token" type="hidden" value="IjBkZGFlMThlOTA5N2JkYWNkNmZlZjkyYjZlNmIwMTIwZDg5ODM5NDAi.ahEOiw.ttGa8GU0oT6QNPf0fqvgOJGSbqk">

            <div class="mb-3">
                <label class="form-label" for="email">
                    <i class="bi bi-envelope me-1"></i>Email
                </label>
                <input class="form-control" id="email" name="email" placeholder="nama@elohimhotel.com" required type="text" value="">
                
            </div>

            <div class="mb-3">
                <label class="form-label" for="password">
                    <i class="bi bi-lock me-1"></i>Password
                </label>
                <input class="form-control" id="password" name="password" placeholder="••••••••" required type="password" value="">
                
            </div>

            <div class="mb-4 form-check" style="padding-left:0">
                <label class="form-check-label" style="font-size:.88rem;color:var(--muted)" for="remember">
                    <input class="form-check-input" id="remember" name="remember" style="accent-color:var(--gold)" type="checkbox" value="y">
                    Ingat saya di perangkat ini
                </label>
            </div>

            <input class="btn btn-success-elohim btn-elohim w-100 py-2" id="submit" name="submit" type="submit" value="Login">
        </form>

        <div class="text-center mt-3">
            <small class="text-muted">Demo: admin@hotel.com / admin123</small>
        </div>
    </div>
</div>

</main>

<!-- ═══════════════════════════════════════  FOOTER  ════ -->
<footer class="footer-elohim">
    <div class="container">
        <img src="/static/logos/logo-elohim.png" alt="Elohim Hotel" class="footer-logo-img"> Elohim Hotel — Sistem Absensi &copy; 2026
    </div>
</footer>

<!-- ═══════════════════════════════════════  SCRIPTS  ════ -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>